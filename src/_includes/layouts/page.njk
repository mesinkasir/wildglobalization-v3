{% extends "layouts/base.njk" %}

{% block content %}
<article class="content-page section">
	<div class="section-inner content-page__inner">
		{% if eyebrow %}
			<p class="section-label">{{ eyebrow }}</p>
		{% endif %}
		<h1>{{ title }}</h1>
		<div class="content-card">
			{% if show_toc %}
				{{ content | toc | safe }}
			{% endif %}
			{{ content | safe }}
		</div>
	</div>
</article>
{% endblock %}
